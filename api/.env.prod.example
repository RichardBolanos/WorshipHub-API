# Configuración de entorno de producción para WorshipHub
# NUNCA commitear este archivo con valores reales

# Perfil de Spring Boot
SPRING_PROFILES_ACTIVE=prod

# Configuración de Base de Datos PostgreSQL
DATABASE_URL=jdbc:postgresql://your-prod-host:5432/worshiphub_prod
DATABASE_USERNAME=worshiphub_user
DATABASE_PASSWORD=your-secure-production-password

# Configuración JPA
DDL_AUTO=validate
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false

# Configuración Flyway
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=false
FLYWAY_VALIDATE_ON_MIGRATE=true

# Pool de conexiones
DB_POOL_SIZE=20
DB_POOL_MIN_IDLE=5

# JWT Configuration (USAR VALORES SEGUROS EN PRODUCCIÓN)
JWT_SECRET=your-super-secure-jwt-secret-key-minimum-32-characters-long
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=86400000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/worshiphub-prod.log

# Server
SERVER_PORT=8080

# SSL (habilitado para producción)
SSL_ENABLED=true
SSL_REQUIRED=true

# H2 Console (siempre deshabilitado en producción)
H2_CONSOLE_ENABLED=false